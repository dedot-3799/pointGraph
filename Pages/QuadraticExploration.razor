@page "/quadratic"
@using PointGraph.Math
@using System.Text
@using Microsoft.AspNetCore.Components.Web

<PageTitle>2次関数パラメータ探究</PageTitle>

<div class="container-fluid mt-4">
    <div class="row mb-3">
        <div class="col-12">
            <h2>2次関数エクスプローラー</h2>
            <p class="text-muted">「3つのパラメータが決まれば2次関数が一意に定まる」関係をインタラクティブに学習できます。一般形と標準形を同期して操作可能です。</p>
        </div>
    </div>

    <div class="row">
        <!-- グラフ描画エリア -->
        <div class="col-auto position-relative" style="width: 540px; height: 540px;">
            <svg id="explorationCanvas" 
                 width="500" 
                 height="500" 
                 style="border:1px solid #ccc; background-color: #f9f9f9; user-select: none;">
                
                <!-- 1. グリッド線 -->
                @for (double offset = 0; offset <= _coordinateSystem.Width / 2; offset += _coordinateSystem.Scale)
                {
                    var rightX = _coordinateSystem.Width / 2 + offset;
                    var leftX = _coordinateSystem.Width / 2 - offset;
                    var bottomY = _coordinateSystem.Height / 2 + offset;
                    var topY = _coordinateSystem.Height / 2 - offset;

                    <line x1="@rightX" y1="0" x2="@rightX" y2="@_coordinateSystem.Height" stroke="#e9e9e9" stroke-width="1" />
                    <line x1="0" y1="@bottomY" x2="@_coordinateSystem.Width" y2="@bottomY" stroke="#e9e9e9" stroke-width="1" />
                    
                    if (offset > 0)
                    {
                        <line x1="@leftX" y1="0" x2="@leftX" y2="@_coordinateSystem.Height" stroke="#e9e9e9" stroke-width="1" />
                        <line x1="0" y1="@topY" x2="@_coordinateSystem.Width" y2="@topY" stroke="#e9e9e9" stroke-width="1" />
                    }
                }

                <!-- 2. 座標軸 -->
                <line x1="0" y1="@(_coordinateSystem.Height/2)" 
                      x2="@_coordinateSystem.Width" y2="@(_coordinateSystem.Height/2)" 
                      stroke="#333" stroke-width="2" />
                <line x1="@(_coordinateSystem.Width/2)" y1="0" 
                      x2="@(_coordinateSystem.Width/2)" y2="@_coordinateSystem.Height" 
                      stroke="#333" stroke-width="2" />

                <!-- 軸矢印 -->
                <polygon points="@($"{_coordinateSystem.Width - 10},{_coordinateSystem.Height/2 - 4} {_coordinateSystem.Width},{_coordinateSystem.Height/2} {_coordinateSystem.Width - 10},{_coordinateSystem.Height/2 + 4}")" fill="#333" />
                <polygon points="@($"{_coordinateSystem.Width/2 - 4},10 {_coordinateSystem.Width/2},0 {_coordinateSystem.Width/2 + 4},10")" fill="#333" />

                <!-- 軸ラベル -->
                <svg:text x="@(_coordinateSystem.Width - 15)" y="@(_coordinateSystem.Height/2 + 20)" fill="#333" font-size="14" font-weight="bold">x</svg:text>
                <svg:text x="@(_coordinateSystem.Width/2 - 18)" y="22" fill="#333" font-size="14" font-weight="bold">y</svg:text>
                <svg:text x="@(_coordinateSystem.Width/2 - 16)" y="@(_coordinateSystem.Height/2 + 18)" fill="#666" font-size="12">O</svg:text>

                <!-- 3. 2次関数曲線 -->
                <path d="@GetQuadraticPathData()" fill="none" stroke="blue" stroke-width="2.5" />

                <!-- 4. 対称軸と頂点の描画 -->
                @{
                    var (screenVx, screenVy) = _coordinateSystem.CartesianToScreen(_p, _q);
                    <line x1="@screenVx" y1="0" x2="@screenVx" y2="@_coordinateSystem.Height" 
                          stroke="purple" stroke-width="1.5" stroke-dasharray="4 4" />
                    
                    <circle cx="@screenVx" cy="@screenVy" r="6" fill="purple" stroke="white" stroke-width="2" />
                    
                    <svg:text x="@(screenVx + 10)" y="@(screenVy - 10)" fill="purple" font-size="12" font-weight="bold">
                        V: (@_p.ToString("F1"), @_q.ToString("F1"))
                    </svg:text>
                }
            </svg>
        </div>

        <!-- パラメータコントロール -->
        <div class="col-md-6">
            <!-- タブ切り替え -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-light">
                    <ul class="nav nav-tabs card-header-tabs">
                        <li class="nav-item">
                            <button class="nav-link @(_activeTab == TabType.General ? "active fw-bold" : "")" 
                                    @onclick="() => SetActiveTab(TabType.General)">一般形: y = ax² + bx + c</button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link @(_activeTab == TabType.Vertex ? "active fw-bold" : "")" 
                                    @onclick="() => SetActiveTab(TabType.Vertex)">標準形: y = a(x - p)² + q</button>
                        </li>
                    </ul>
                </div>
                
                <div class="card-body">
                    @if (_activeTab == TabType.General)
                    {
                        <div class="mb-4 text-center p-3 bg-white border rounded">
                            @((MarkupString)GetFormattedGeneralForm())
                            <p class="text-muted small mb-0 mt-2">一般形では、それぞれの係数が変化した際の影響が直接観察できます。</p>
                        </div>

                        <!-- スライダー a -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label class="fw-bold">係数 a (開き具合・向き): <span class="badge bg-secondary font-monospace">@_a.ToString("F2")</span></label>
                                <span class="text-muted small">※ a ≠ 0</span>
                            </div>
                            <input type="range" class="form-range" min="-5.0" max="5.0" step="0.1" 
                                   value="@_a" @oninput="OnGeneralAInput" />
                            <div class="d-flex justify-content-between text-muted small">
                                <span>-5.0 (上に凸)</span>
                                <span>0.0</span>
                                <span>5.0 (下に凸)</span>
                            </div>
                        </div>

                        <!-- スライダー b -->
                        <div class="mb-3">
                            <label class="fw-bold mb-1">係数 b (軸の位置に影響): <span class="badge bg-secondary font-monospace">@_b.ToString("F2")</span></label>
                            <input type="range" class="form-range" min="-10.0" max="10.0" step="0.1" 
                                   value="@_b" @oninput="OnGeneralBInput" />
                            <div class="d-flex justify-content-between text-muted small">
                                <span>-10.0</span>
                                <span>0.0</span>
                                <span>10.0</span>
                            </div>
                        </div>

                        <!-- スライダー c -->
                        <div class="mb-3">
                            <label class="fw-bold mb-1">定数 c (y切片): <span class="badge bg-secondary font-monospace">@_c.ToString("F2")</span></label>
                            <input type="range" class="form-range" min="-10.0" max="10.0" step="0.1" 
                                   value="@_c" @oninput="OnGeneralCInput" />
                            <div class="d-flex justify-content-between text-muted small">
                                <span>-10.0 (下へ移動)</span>
                                <span>0.0</span>
                                <span>10.0 (上へ移動)</span>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4 text-center p-3 bg-white border rounded">
                            @((MarkupString)GetFormattedVertexForm())
                            <p class="text-muted small mb-0 mt-2">標準形（平方完成形）では、頂点の座標が直感的にわかります。</p>
                        </div>

                        <!-- スライダー a -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label class="fw-bold">係数 a (開き具合・向き): <span class="badge bg-secondary font-monospace">@_a.ToString("F2")</span></label>
                                <span class="text-muted small">※ a ≠ 0</span>
                            </div>
                            <input type="range" class="form-range" min="-5.0" max="5.0" step="0.1" 
                                   value="@_a" @oninput="OnVertexAInput" />
                            <div class="d-flex justify-content-between text-muted small">
                                <span>-5.0</span>
                                <span>0.0</span>
                                <span>5.0</span>
                            </div>
                        </div>

                        <!-- スライダー p -->
                        <div class="mb-3">
                            <label class="fw-bold mb-1">頂点 x座標 p (左右平行移動): <span class="badge bg-secondary font-monospace">@_p.ToString("F2")</span></label>
                            <input type="range" class="form-range" min="-10.0" max="10.0" step="0.1" 
                                   value="@_p" @oninput="OnVertexPInput" />
                            <div class="d-flex justify-content-between text-muted small">
                                <span>-10.0 (左へ)</span>
                                <span>0.0 (中心)</span>
                                <span>10.0 (右へ)</span>
                            </div>
                        </div>

                        <!-- スライダー q -->
                        <div class="mb-3">
                            <label class="fw-bold mb-1">頂点 y座標 q (上下平行移動): <span class="badge bg-secondary font-monospace">@_q.ToString("F2")</span></label>
                            <input type="range" class="form-range" min="-10.0" max="10.0" step="0.1" 
                                   value="@_q" @oninput="OnVertexQInput" />
                            <div class="d-flex justify-content-between text-muted small">
                                <span>-10.0 (下へ)</span>
                                <span>0.0 (中心)</span>
                                <span>10.0 (上へ)</span>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- 式の相互変換と解説 -->
            <div class="card shadow-sm bg-light">
                <div class="card-body">
                    <h5 class="card-title fw-bold">パラメータの対応関係と特徴</h5>
                    <ul class="mb-0">
                        <li>
                            <strong>頂点の座標 (p, q)</strong>: 
                            <span class="text-purple font-monospace">(@_p.ToString("F2"), @_q.ToString("F2"))</span>
                            <br />
                            <div class="mt-1">
                                <math display="inline">
                                    <mi>p</mi><mo>=</mo><mo>-</mo><mfrac><mi>b</mi><mrow><mn>2</mn><mi>a</mi></mrow></mfrac>
                                    <mtext>,&nbsp;&nbsp;</mtext>
                                    <mi>q</mi><mo>=</mo><mi>c</mi><mo>-</mo><mfrac><msup><mi>b</mi><mn>2</mn></msup><mrow><mn>4</mn><mi>a</mi></mrow></mfrac>
                                </math>
                            </div>
                        </li>
                        <li class="mt-3">
                            <strong>対称軸の式</strong>: 
                            <span class="text-purple font-monospace">x = @_p.ToString("F2")</span>
                        </li>
                        <li class="mt-3">
                            <strong>一般形 ↔ 標準形の相互展開プロセス (MathML)</strong>:
                            <div class="p-2 bg-white rounded mt-1 text-center" style="border: 1px solid #ddd; overflow-x: auto;">
                                @((MarkupString)GetFormattedConversion())
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly CoordinateSystem _coordinateSystem = new CoordinateSystem(width: 500, height: 500, scale: 20);

    private double _a = 1.0;
    private double _b = 0.0;
    private double _c = 0.0;

    private double _p = 0.0;
    private double _q = 0.0;

    private enum TabType { General, Vertex }
    private TabType _activeTab = TabType.General;

    private void SetActiveTab(TabType tab)
    {
        _activeTab = tab;
    }

    private void OnGeneralAInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val))
        {
            _a = val == 0.0 ? 0.1 : val;
            SyncGeneralToVertex();
        }
    }

    private void OnGeneralBInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val))
        {
            _b = val;
            SyncGeneralToVertex();
        }
    }

    private void OnGeneralCInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val))
        {
            _c = val;
            SyncGeneralToVertex();
        }
    }

    private void SyncGeneralToVertex()
    {
        _p = -_b / (2 * _a);
        _q = _c - (_b * _b) / (4 * _a);
    }

    private void OnVertexAInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val))
        {
            _a = val == 0.0 ? 0.1 : val;
            SyncVertexToGeneral();
        }
    }

    private void OnVertexPInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val))
        {
            _p = val;
            SyncVertexToGeneral();
        }
    }

    private void OnVertexQInput(ChangeEventArgs e)
    {
        if (double.TryParse(e.Value?.ToString(), out double val))
        {
            _q = val;
            SyncVertexToGeneral();
        }
    }

    private void SyncVertexToGeneral()
    {
        _b = -2 * _a * _p;
        _c = _a * _p * _p + _q;
    }

    private string GetFormattedGeneralForm()
    {
        var fracA = Fraction.FromDouble(_a);
        var fracB = Fraction.FromDouble(_b);
        var fracC = Fraction.FromDouble(_c);

        var sb = new StringBuilder();
        sb.Append("<math display=\"block\" style=\"font-size: 22px; color: #007bff;\"><mi>y</mi><mo>=</mo>");

        bool isFirst = true;

        // a
        if (fracA.Numerator != 0)
        {
            bool isNeg = fracA.Numerator < 0;
            if (isNeg) sb.Append("<mo>-</mo>");
            
            var absA = new Fraction(System.Math.Abs(fracA.Numerator), fracA.Denominator);
            if (absA != Fraction.One)
            {
                sb.Append(absA.ToMathML());
            }
            sb.Append("<msup><mi>x</mi><mn>2</mn></msup>");
            isFirst = false;
        }

        // b
        if (fracB.Numerator != 0)
        {
            bool isNeg = fracB.Numerator < 0;
            if (!isFirst)
            {
                sb.Append(isNeg ? "<mo>-</mo>" : "<mo>+</mo>");
            }
            else if (isNeg)
            {
                sb.Append("<mo>-</mo>");
            }
            
            var absB = new Fraction(System.Math.Abs(fracB.Numerator), fracB.Denominator);
            if (absB != Fraction.One)
            {
                sb.Append(absB.ToMathML());
            }
            sb.Append("<mi>x</mi>");
            isFirst = false;
        }

        // c
        if (fracC.Numerator != 0)
        {
            bool isNeg = fracC.Numerator < 0;
            if (!isFirst)
            {
                sb.Append(isNeg ? "<mo>-</mo>" : "<mo>+</mo>");
            }
            else if (isNeg)
            {
                sb.Append("<mo>-</mo>");
            }
            
            var absC = new Fraction(System.Math.Abs(fracC.Numerator), fracC.Denominator);
            sb.Append(absC.ToMathML());
            isFirst = false;
        }
        
        if (isFirst)
        {
            sb.Append("<mn>0</mn>");
        }

        sb.Append("</math>");
        return sb.ToString();
    }

    private string GetFormattedVertexForm()
    {
        var fracA = Fraction.FromDouble(_a);
        var fracP = Fraction.FromDouble(_p);
        var fracQ = Fraction.FromDouble(_q);

        var sb = new StringBuilder();
        sb.Append("<math display=\"block\" style=\"font-size: 22px; color: #007bff;\"><mi>y</mi><mo>=</mo>");

        // a
        if (fracA.Numerator < 0) sb.Append("<mo>-</mo>");
        var absA = new Fraction(System.Math.Abs(fracA.Numerator), fracA.Denominator);
        if (absA != Fraction.One)
        {
            sb.Append(absA.ToMathML());
        }

        // (x - p)^2
        sb.Append("<mo>(</mo><mi>x</mi>");
        if (fracP.Numerator != 0)
        {
            bool isNeg = fracP.Numerator < 0;
            sb.Append(isNeg ? "<mo>+</mo>" : "<mo>-</mo>");
            var absP = new Fraction(System.Math.Abs(fracP.Numerator), fracP.Denominator);
            sb.Append(absP.ToMathML());
        }
        sb.Append("<mo>)</mo><msup><mo></mo><mn>2</mn></msup>");

        // q
        if (fracQ.Numerator != 0)
        {
            bool isNeg = fracQ.Numerator < 0;
            sb.Append(isNeg ? "<mo>-</mo>" : "<mo>+</mo>");
            var absQ = new Fraction(System.Math.Abs(fracQ.Numerator), fracQ.Denominator);
            sb.Append(absQ.ToMathML());
        }

        sb.Append("</math>");
        return sb.ToString();
    }

    private string GetFormattedConversion()
    {
        var fracA = Fraction.FromDouble(_a);
        var fracP = Fraction.FromDouble(_p);
        var fracQ = Fraction.FromDouble(_q);

        var fracTwoP = fracP * new Fraction(2);
        var fracPSquared = fracP * fracP;
        var fracAPSquared = fracA * fracPSquared;
        var fracB = -fracA * fracTwoP;
        var fracC = fracAPSquared + fracQ;

        var sb = new StringBuilder();
        sb.Append("<math display=\"block\" style=\"font-size: 15px;\">");
        
        sb.Append("<mi>y</mi><mo>=</mo>");
        if (fracA.Numerator < 0) sb.Append("<mo>-</mo>");
        var absA = new Fraction(System.Math.Abs(fracA.Numerator), fracA.Denominator);
        if (absA != Fraction.One) sb.Append(absA.ToMathML());
        sb.Append("<mo>(</mo><mi>x</mi>");
        if (fracP.Numerator != 0)
        {
            bool isNeg = fracP.Numerator < 0;
            sb.Append(isNeg ? "<mo>+</mo>" : "<mo>-</mo>");
            sb.Append(new Fraction(System.Math.Abs(fracP.Numerator), fracP.Denominator).ToMathML());
        }
        sb.Append("<mo>)</mo><msup><mo></mo><mn>2</mn></msup>");
        if (fracQ.Numerator != 0)
        {
            bool isNeg = fracQ.Numerator < 0;
            sb.Append(isNeg ? "<mo>-</mo>" : "<mo>+</mo>");
            sb.Append(new Fraction(System.Math.Abs(fracQ.Numerator), fracQ.Denominator).ToMathML());
        }

        sb.Append("<mtext>&nbsp;&nbsp;&rArr;&nbsp;&nbsp;</mtext>");

        sb.Append("<mi>y</mi><mo>=</mo>");
        if (fracA.Numerator < 0) sb.Append("<mo>-</mo>");
        if (absA != Fraction.One) sb.Append(absA.ToMathML());
        sb.Append("<mo>(</mo><msup><mi>x</mi><mn>2</mn></msup>");
        if (fracTwoP.Numerator != 0)
        {
            bool isNeg = fracTwoP.Numerator < 0;
            sb.Append(isNeg ? "<mo>+</mo>" : "<mo>-</mo>");
            sb.Append(new Fraction(System.Math.Abs(fracTwoP.Numerator), fracTwoP.Denominator).ToMathML());
            sb.Append("<mi>x</mi>");
        }
        if (fracPSquared.Numerator != 0)
        {
            sb.Append("<mo>+</mo>");
            sb.Append(fracPSquared.ToMathML());
        }
        sb.Append("<mo>)</mo>");
        if (fracQ.Numerator != 0)
        {
            bool isNeg = fracQ.Numerator < 0;
            sb.Append(isNeg ? "<mo>-</mo>" : "<mo>+</mo>");
            sb.Append(new Fraction(System.Math.Abs(fracQ.Numerator), fracQ.Denominator).ToMathML());
        }

        sb.Append("<mtext>&nbsp;&nbsp;&rArr;&nbsp;&nbsp;</mtext>");

        sb.Append("<mi>y</mi><mo>=</mo>");
        if (fracA.Numerator != 0)
        {
            bool isNeg = fracA.Numerator < 0;
            if (isNeg) sb.Append("<mo>-</mo>");
            if (absA != Fraction.One) sb.Append(absA.ToMathML());
            sb.Append("<msup><mi>x</mi><mn>2</mn></msup>");
        }
        if (fracB.Numerator != 0)
        {
            bool isNeg = fracB.Numerator < 0;
            sb.Append(isNeg ? "<mo>-</mo>" : "<mo>+</mo>");
            sb.Append(new Fraction(System.Math.Abs(fracB.Numerator), fracB.Denominator).ToMathML());
            sb.Append("<mi>x</mi>");
        }
        if (fracC.Numerator != 0)
        {
            bool isNeg = fracC.Numerator < 0;
            sb.Append(isNeg ? "<mo>-</mo>" : "<mo>+</mo>");
            sb.Append(new Fraction(System.Math.Abs(fracC.Numerator), fracC.Denominator).ToMathML());
        }

        sb.Append("</math>");
        return sb.ToString();
    }

    private string GetQuadraticPathData()
    {
        var pathBuilder = new StringBuilder();
        bool first = true;

        for (double px = 0; px <= _coordinateSystem.Width; px += 2)
        {
            var (x, _) = _coordinateSystem.ScreenToCartesian(px, 0);
            double y = _a * (x - _p) * (x - _p) + _q;
            var (_, py) = _coordinateSystem.CartesianToScreen(x, y);

            if (double.IsNaN(py) || double.IsInfinity(py))
                continue;

            if (first)
            {
                pathBuilder.Append($"M {px:F1} {py:F1}");
                first = false;
            }
            else
            {
                pathBuilder.Append($" L {px:F1} {py:F1}");
            }
        }

        return pathBuilder.ToString();
    }
}
